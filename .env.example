# cp .env.example .env  then fill in your values

NODE_ENV=development
PORT=5000
TRUST_PROXY=false

DB_HOST=localhost
DB_PORT=3306
DB_NAME=sunacare
DB_USER=root
DB_PASSWORD=
DB_SYNC=false

JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=15
RATE_LIMIT_MAX_REQUESTS=500

# CORS origins (comma-separated)
ALLOWED_ORIGINS=https://app.sunacare.org,https://admin.sunacare.org,https://responder.sunacare.org,http://localhost:3000,http://localhost:3001,http://localhost:3002
FRONTEND_URL=https://app.sunacare.org

# SMTP (free provider examples: Brevo SMTP, Gmail app password)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=a5a124001@smtp-brevo.com
SMTP_PASS=passkey-goes-here
SMTP_FROM=sunacare.org@gmail.com
OTP_FROM_EMAIL=sunacare.org@gmail.com

# Cookie settings (only needed if you switch to cookie auth/session)
COOKIE_DOMAIN=.sunacare.org
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
