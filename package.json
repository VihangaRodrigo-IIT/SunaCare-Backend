{
  "name": "sunacare-backend",
  "version": "2.0.0",
  "description": "Animal Rescue Platform — REST API backend",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "build": "node -e \"const fs=require('fs'); if(!fs.existsSync('src/server.js')){console.error('Missing src/server.js'); process.exit(1);} console.log('Backend build check passed (no transpilation required).');\"",
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed": "node database/seed.js"
  },
  "keywords": [
    "express",
    "backend",
    "api",
    "animal-rescue",
    "mysql"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.0.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "mysql2": "^3.6.5",
    "sequelize": "^6.35.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
